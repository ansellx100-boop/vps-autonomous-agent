# API для LLM (укажите один или оба)
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Telegram: отправка отчётов и бот /report
# TELEGRAM_BOT_TOKEN=123456:ABC...   — токен от @BotFather
# TELEGRAM_WEBHOOK_URL=https://ВАШ-ДОМЕН.up.railway.app/telegram-webhook  — обязательно на Railway (иначе бот не получит сообщения)
# TELEGRAM_REPORT_CHAT_IDS=123456789 — ID чатов, куда слать ежедневный отчёт (через запятую)
# TELEGRAM_ALLOWED_CHAT_IDS=123456789 — кто может писать боту /report (если не задано — используются TELEGRAM_REPORT_CHAT_IDS)

# Режим: "poll" (опрос очереди) или "webhook" (HTTP endpoint)
MODE=poll
# Интервал опроса в секундах (для MODE=poll)
POLL_INTERVAL_SEC=60

# Секрет для webhook (заголовок X-Webhook-Secret)
WEBHOOK_SECRET=your-random-secret

# Порт для webhook-сервера (при MODE=webhook)
PORT=3030

# Управление из Cursor/локально: URL задеплоенного агента (Railway и т.д.)
# AGENT_URL=https://ваш-проект.up.railway.app

# Garmin Connect (для анализа тренировок)
# GARMIN_EMAIL=you@example.com
# GARMIN_PASSWORD=your-password
# Для безопасного локального теста можно использовать mock-файл:
# GARMIN_USE_MOCK=1
# GARMIN_MOCK_FILE=tests/fixtures/garmin-activities.sample.json
# Кэш сессии Garmin (уменьшает число логинов и риск 429)
# GARMIN_TOKEN_DIR=data/garmin-tokens
# GARMIN_DISABLE_TOKEN_CACHE=0
# GARMIN_FORCE_LOGIN=0
# Retry при 429 (экспоненциальный backoff: base, 2*base, 4*base...)
# GARMIN_RETRY_ATTEMPTS=4
# GARMIN_RETRY_BASE_MS=30000

# Ежедневный сбор данных (cron): 1 = включён, 0 = выключен
CRON_ENABLED=1
# Расписание в формате cron (UTC). По умолчанию: каждый день в 00:00 UTC
CRON_COLLECT_SCHEDULE=0 0 * * *

# Ежедневная отправка PDF-отчёта в Telegram (1 = включён)
CRON_REPORT_ENABLED=1
# Расписание: по умолчанию 09:00 UTC. Для 9:00 по Москве: 0 6 * * * (06:00 UTC = 09:00 МСК)
CRON_REPORT_SCHEDULE=0 9 * * *
