# API для LLM — укажите один из ключей (приоритет: OpenAI → Gemini → Groq)
# OPENAI_API_KEY=sk-...
# Google Gemini (бесплатный лимит, ключ: aistudio.google.com/app/apikey)
# GEMINI_API_KEY=
# Groq (бесплатный лимит, ключ: console.groq.com/keys)
# GROQ_API_KEY=

# Опционально: Telegram-бот для приёма задач
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_CHAT_IDS=123456789

# Режим: "poll" (опрос очереди) или "webhook" (HTTP endpoint)
MODE=poll
# Интервал опроса в секундах (для MODE=poll)
POLL_INTERVAL_SEC=60

# Секрет для webhook (заголовок X-Webhook-Secret)
WEBHOOK_SECRET=your-random-secret

# Порт для webhook-сервера (при MODE=webhook)
PORT=3030

# Управление из Cursor/локально: URL задеплоенного агента (Railway и т.д.)
# AGENT_URL=https://https://railway.com/project/a886b650-dc78-428a-b8a6-5dd71d77c97f?
.up.railway.app
